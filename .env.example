# Server Configuration
SERVER_PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tesana-br

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# WebSocket
SOCKET_IO_PORT=5000
SOCKET_IO_PATH=/socket.io

# AWS/Cloud Storage (for assets)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=tesana-br-assets
AWS_REGION=us-east-1

# Game Configuration
MAX_PLAYERS_PER_MATCH=100
MATCH_DURATION_MINUTES=25
ZONE_SHRINK_INTERVAL=180

# Client Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000
